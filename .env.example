PROJECT_NAME="Community App Backend"
BASE_URL="/api/v1"
ENVIRONMENT="development"
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173"]'

SECRET_KEY="replace-with-at-least-32-random-characters"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=15

POSTGRES_USER="community_app"
POSTGRES_PASSWORD="replace-local-database-password"
POSTGRES_DB="community_app"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432

# Only used by the explicit development seed command.
SEED_DEFAULT_PASSWORD="replace-local-demo-password"
