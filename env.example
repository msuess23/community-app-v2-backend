# Community App backend environment configuration
# Copy this file to .env for local development:
#   cp .env.example .env
#
# Never use the example secrets or passwords in production.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Human-readable application name used in OpenAPI and API responses.
PROJECT_NAME="Community App Fachverfahren Backend"

# Common prefix for all API routes. Keep the leading slash and omit a trailing slash.
BASE_URL="/api/v1"

# Allowed values: development, test, production.
ENVIRONMENT="development"

# JSON array of browser origins allowed to call the API.
# Add the deployed authority and citizen client origins in production.
CORS_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

# -----------------------------------------------------------------------------
# JWT and authentication
# -----------------------------------------------------------------------------

# Replace with a random value of at least 32 characters.
# Example generation command:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY="development-only-change-this-secret-key-1234567890"

# The current implementation supports HS256.
ALGORITHM="HS256"

# Access-token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh-token lifetime in days.
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# These values are also consumed by compose.yml for the PostgreSQL container.
POSTGRES_USER="community_app"
POSTGRES_PASSWORD="development-only-change-this-database-password"
POSTGRES_DB="community_app"

# Use localhost when the API runs directly on the host machine.
# Use db when the API runs in the same Compose network as the database service.
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432

# DATABASE_URL is derived automatically from the atomic PostgreSQL settings above.
# Do not define DATABASE_URL separately.

# -----------------------------------------------------------------------------
# Demo seeding
# -----------------------------------------------------------------------------

# Run the idempotent demo seed during application startup.
# Production configuration rejects RUN_SEED_ON_STARTUP=true.
RUN_SEED_ON_STARTUP=false

# Password assigned to every generated demo user.
# Required when startup seeding is enabled and when running:
#   python -m scripts.seed.run_seed
# Must contain at least 8 characters.
SEED_DEFAULT_PASSWORD="ChangeThisDemoPassword123!"

# -----------------------------------------------------------------------------
# Scheduled maintenance
# -----------------------------------------------------------------------------

# Enable the in-process maintenance scheduler.
# Disable this for tests or when another process owns scheduled jobs.
ENABLE_SCHEDULER=true

# Daily execution time for deep anonymization, interpreted in the server's local time.
DEEP_ANONYMIZATION_HOUR=3
DEEP_ANONYMIZATION_MINUTE=0

# Retention period for eligible deactivated-citizen history snapshots.
CITIZEN_HISTORY_RETENTION_DAYS=180

# -----------------------------------------------------------------------------
# Ticket image storage
# -----------------------------------------------------------------------------

# Local storage directory for event-sourced ticket images.
TICKET_MEDIA_ROOT="./data/ticket-media"

# Maximum image size in bytes. The example value is 5 MiB.
TICKET_IMAGE_MAX_BYTES=5242880

# JSON array of accepted declared MIME types. File contents are validated separately.
TICKET_IMAGE_ALLOWED_MIME_TYPES='["image/jpeg","image/png","image/webp"]'

# -----------------------------------------------------------------------------
# Info image storage
# -----------------------------------------------------------------------------

# Local storage directory for CRUD-owned public information images.
INFO_MEDIA_ROOT="./data/info-media"

# Maximum image size in bytes. The example value is 5 MiB.
INFO_IMAGE_MAX_BYTES=5242880

# JSON array of accepted declared MIME types. File contents are validated separately.
INFO_IMAGE_ALLOWED_MIME_TYPES='["image/jpeg","image/png","image/webp"]'

# -----------------------------------------------------------------------------
# Appointment document storage
# -----------------------------------------------------------------------------

# Local storage directory for immutable, versioned appointment PDFs.
APPOINTMENT_DOCUMENT_ROOT="./data/appointment-documents"

# Maximum PDF size in bytes. The example value is 10 MiB.
APPOINTMENT_DOCUMENT_MAX_BYTES=10485760
